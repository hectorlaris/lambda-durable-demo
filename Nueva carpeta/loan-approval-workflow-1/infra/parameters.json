      "Type": "String",
      "Default": "LoanApplications"
    },
    "LambdaExecutionRole": {
      "Type": "String",
      "Default": "arn:aws:iam::123456789012:role/lambda-execution-role"
    },
    "ApiGatewayStage": {
      "Type": "String",
      "Default": "dev"
    },
    "LoanApprovalFunction": {
      "Type": "String",
      "Default": "ApproveOrRejectLoan"
    },
    "CreditScoreFunction": {
      "Type": "String",
      "Default": "EvaluateCreditScore"
    },
    "NotifyApplicantFunction": {
      "Type": "String",
      "Default": "NotifyApplicant"
    },
    "SubmitLoanApplicationFunction": {
      "Type": "String",
      "Default": "SubmitLoanApplication"
    }
  }
}