@startuml C1_Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Loan Approval Workflow - C1 System Context

Person(applicant, "Solicitante", "Persona que solicita un préstamo")
Person(analyst, "Analista de Riesgo", "Revisa casos manuales")
System_Ext(creditBureau, "Buró de Crédito", "Servicio externo de score")
System_Boundary(loanSys, "Loan Approval Workflow") {
  System(workflow, "Loan Approval System", "Orquesta validación y decisión del préstamo")
}

Rel(applicant, workflow, "Envía solicitud / consulta estado", "HTTPS")
Rel(analyst, workflow, "Aprueba/rechaza casos excepcionales", "Web/HTTPS")
Rel(workflow, creditBureau, "Consulta historial y score", "API")

@enduml