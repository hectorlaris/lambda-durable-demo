@startuml C3_Component_DecisionLambda
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Loan Approval Workflow - C3 Decision Lambda Components

Container_Boundary(decisionLambda, "Decision Lambda") {
  Component(handler, "Handler", "Node.js/Python Lambda handler", "Entrada del evento de Step Functions")
  Component(validator, "Input Validator", "Library", "Valida schema y campos requeridos")
  Component(ruleEngine, "Rule Engine", "Domain service", "Aplica políticas de elegibilidad")
  Component(creditClient, "Credit Bureau Client", "HTTP client", "Consulta score externo")
  Component(repo, "Loan Repository", "DynamoDB adapter", "Lee/escribe solicitud y estado")
  Component(audit, "Audit Logger", "Utility", "Registra trazabilidad")
}

ContainerDb(db, "Loan Data", "DynamoDB", "Persistencia")
System_Ext(creditBureau, "Buró de Crédito", "API externa")
Container(orchestrator, "Approval Orchestrator", "Step Functions", "Orquestador")

Rel(orchestrator, handler, "Invoca tarea")
Rel(handler, validator, "Valida input")
Rel(handler, ruleEngine, "Evalúa")
Rel(ruleEngine, creditClient, "Obtiene score")
Rel(handler, repo, "Actualiza estado")
Rel(handler, audit, "Registra eventos")
Rel(repo, db, "PutItem/GetItem/UpdateItem")
Rel(creditClient, creditBureau, "HTTPS")

@enduml